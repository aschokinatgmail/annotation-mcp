# ───────────────────────────────────────────────────────────────────────
# Build / Python artifacts
# ───────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
wheels/
*.spec

# ───────────────────────────────────────────────────────────────────────
# Virtual environments
# ───────────────────────────────────────────────────────────────────────
.venv/
venv/
env/
.python-version

# ───────────────────────────────────────────────────────────────────────
# Test / coverage
# ───────────────────────────────────────────────────────────────────────
.coverage
.coverage.*
coverage.xml
htmlcov/
.pytest_cache/
.ruff_cache/

# ───────────────────────────────────────────────────────────────────────
# Editor / OS
# ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# ───────────────────────────────────────────────────────────────────────
# Local / secrets (never commit)
# ───────────────────────────────────────────────────────────────────────
.env
.env.local
*.local.toml
secrets/

# ───────────────────────────────────────────────────────────────────────
# Image files — NEVER commit. Tests generate synthetic fixtures at
# runtime via conftest.py. Real photos must be added locally.
# ───────────────────────────────────────────────────────────────────────
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.tif
*.tiff
*.heic
*.heif
*.HEIC
*.HEIF
*.webp
*.ico
*.svg

# ───────────────────────────────────────────────────────────────────────
# Logs
# ───────────────────────────────────────────────────────────────────────
*.log
logs/
